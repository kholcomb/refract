{
  "name": "refract",
  "private": true,
  "version": "1.0.0",
  "description": "Anti-pattern detector — GitHub Action + VS Code extension monorepo",
  "workspaces": [
    "packages/core",
    "packages/action",
    "packages/vscode"
  ],
  "scripts": {
    "build:sidecars": "tsc language-packs/typescript/scripts/ast_checks.ts --outDir language-packs/typescript/scripts --esModuleInterop --module commonjs --target ES2022 --skipLibCheck --resolveJsonModule",
    "build": "npm run build:sidecars && npm run build --workspaces",
    "test": "npm test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "license": "MIT",
  "dependencies": {
    "@typescript-eslint/typescript-estree": "^8.0.0"
  }
}
