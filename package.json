{
  "name": "antipattern-detector",
  "version": "1.0.0",
  "description": "GitHub Action that detects code anti-patterns and creates structured findings for AI agent consumption",
  "main": "dist/index.js",
  "scripts": {
    "build:sidecars": "tsc language-packs/typescript/scripts/ast_checks.ts --outDir language-packs/typescript/scripts --esModuleInterop --module commonjs --target ES2022 --skipLibCheck --resolveJsonModule",
    "build": "npm run build:sidecars && ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": ["github-action", "anti-patterns", "code-quality", "static-analysis"],
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "@typescript-eslint/typescript-estree": "^8.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0"
  }
}
